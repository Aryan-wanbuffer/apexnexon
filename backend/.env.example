# MongoDB Atlas connection (one cluster)
MONGO_URL="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"

# Main database (status checks, general data)
DB_NAME="apexnexon"

# Optional: separate databases on the same cluster (if unset, DB_NAME is used)
DB_CONTACT="apexnexon_contact"
DB_BLOG="apexnexon_blog"

# Blog editor: only requests with header X-Blog-Edit-Key matching this value can create posts. Leave empty to allow anyone (not recommended for production).
# BLOG_EDIT_KEY=your-secret-edit-key

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS="*"
